# ============================================================
# Environment Variables Template
# AI Weather Prediction Trading Agent
# Copy this file to .env and fill in your values
# ============================================================

# ─── OpenRouter ─────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
# See https://openrouter.ai/models for available models
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Apify ──────────────────────────────────────────────────
APIFY_API_TOKEN=your_apify_token_here
# Actor to use for weather news scraping
APIFY_ACTOR_ID=apify/web-scraper

# ─── Weather ────────────────────────────────────────────────
# Open-Meteo is free and requires no key.
# Optionally add OpenWeatherMap for fallback.
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./weather_trading.db
DATABASE_PATH=./weather_trading.db

# ─── Portfolio ──────────────────────────────────────────────
INITIAL_CAPITAL=10000.0
MAX_KELLY_FRACTION=0.25
EDGE_THRESHOLD=0.05

# ─── Scheduler ──────────────────────────────────────────────
# Cron expression for automated trading cycle
SCHEDULE_CRON=0 * * * *
# Set to true to run immediately on startup
RUN_ON_STARTUP=true

# ─── FastAPI ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ─── Streamlit ──────────────────────────────────────────────
STREAMLIT_PORT=8501
FASTAPI_BASE_URL=http://localhost:8000

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log
LOG_ROTATION=10 MB
LOG_RETENTION=7 days

# ─── Mock / Stub Mode ────────────────────────────────────────
# Set to true to run without real API keys (uses generated mock data)
MOCK_WEATHER=false
MOCK_LLM=false
MOCK_APIFY=false
MOCK_POLYMARKET=false
